# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Set this to switch from JSON to Postgres automatically.
# Format: postgresql://user:password@host:port/dbname
# DATABASE_URL=postgresql://postgres:secret@localhost:5432/upyog

# ── Elasticsearch ─────────────────────────────────────────────────────────────
# Set this to switch from JSON to Elasticsearch automatically.
# ES_HOST=http://localhost:9200
# ES_INDEX=properties

# ── JSON fallback (default — no config needed) ────────────────────────────────
# JSON_DATA_PATH=properties.json
