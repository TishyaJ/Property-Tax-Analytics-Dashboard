# Data source: "json" (default) | "elasticsearch" | "postgres"
DATA_SOURCE=json

# Path to JSON relative to backend/.env.example
# JSON_DATA_PATH=properties.json

# PostgreSQL (only if DATA_SOURCE=postgres)
# DATABASE_URL=postgresql://user:password@localhost:5432/upyog

# Elasticsearch (only if DATA_SOURCE=elasticsearch)
# ES_HOST=http://localhost:9200
# ES_INDEX=properties
